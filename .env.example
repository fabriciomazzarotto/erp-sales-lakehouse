# SQL Server (ERP source) — use um login dedicado de extração (SELECT-only em erp.*),
# nunca uma conta pessoal/admin. Ver sql/04_create_pipeline_login.sql.
# Requer TCP/IP habilitado na instância (JDBC não suporta Shared Memory/Named Pipes).
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=ERP_Sales
SQLSERVER_USER=erp_extractor
SQLSERVER_PASSWORD=change_me

# Modo de execução do pipeline: "local" (dev, grava Delta em disco) ou "aws" (produção, grava em S3)
RUN_MODE=local
LOCAL_LAKEHOUSE_ROOT=./data/lakehouse

# AWS
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
AWS_REGION=us-east-1
AWS_S3_BUCKET_BRONZE=erp-sales-lakehouse-bronze
AWS_S3_BUCKET_SILVER=erp-sales-lakehouse-silver
AWS_S3_BUCKET_GOLD=erp-sales-lakehouse-gold
AWS_S3_BUCKET_DIAMOND=erp-sales-lakehouse-diamond

# Databricks
DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_TOKEN=change_me
DATABRICKS_CLUSTER_ID=change_me

# Glue / Athena
GLUE_DATABASE_NAME=erp_sales_lakehouse
ATHENA_OUTPUT_S3=s3://erp-sales-lakehouse-athena-results/
